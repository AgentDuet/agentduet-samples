# --- AgentDuet (https://agentduet.com) ---
AGENTDUET_API_KEY=your_agentduet_api_key
AGENTDUET_CONNECTOR_UUID=your_connector_uuid

# --- AWS / Amazon Nova 2 Sonic ---
AWS_REGION=us-east-1
# Prefer IAM role on Lightsail. For local Docker only:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

NOVA_MODEL_ID=amazon.nova-2-sonic-v1:0
NOVA_VOICE_ID=tiffany
# HIGH = faster turn-taking after caller stops speaking (LOW waits longer)
NOVA_ENDPOINTING_SENSITIVITY=HIGH
AUDIO_SAMPLE_RATE=16000

# --- CloudWatch transcript observability ---
CLOUDWATCH_ENABLED=true
CLOUDWATCH_LOG_GROUP=/medical-pretriage/transcripts
CLOUDWATCH_LOG_STREAM_PREFIX=call

# --- Health probe (Docker / Lightsail) ---
HEALTH_HOST=0.0.0.0
HEALTH_PORT=8080
LOG_LEVEL=INFO
